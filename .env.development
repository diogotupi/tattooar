# Servidor local (npm run dev)
VITE_BASE_PATH=/

# JSON servido a partir de `public/` (ex.: public/bundles/arte.json). Por omissão o código usa bundles/onca-teste.json.
# VITE_PUBLIC_BUNDLE=bundles/onca-teste.json

# Opcional: mesma chave que em produção para testar o ecrã de admin localmente.
# VITE_ADMIN_KEY=
